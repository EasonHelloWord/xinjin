JWT_SECRET=dev-secret-change-me

LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
TTS_FILTER_MODEL=qwen3.5-plus

MIMO_API_KEY=your-mimo-api-key
MIMO_TTS_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2-tts
MIMO_TTS_VOICE=mimo_default
MIMO_TTS_FORMAT=pcm16
MIMO_TTS_ENABLE_FINE_TAGS=1

MCP_SERVER_CMD=node dist/index.js
MCP_SERVER_CWD=../mcp_server

# Optional: point to an extra config file relative to back_end or absolute.
# Supports .env-style files and .json files.
# XINJIN_CONFIG_FILE=./config.local.json
