{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node18",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node", "ws"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
