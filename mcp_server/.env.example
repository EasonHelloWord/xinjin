# ── Dify Knowledge API connection ──────────────────────────────────
# Local Dify deployment on port 80 usually works with:
DIFY_BASE_URL=http://localhost
DIFY_API_KEY=your-dify-dataset-api-key-here
# Optional default knowledge base. If omitted, document upload endpoints
# must pass workspaceSlug explicitly.
DIFY_DEFAULT_DATASET_ID=

# Optional legacy aliases kept for migration only:
# ANYTHINGLLM_BASE_URL=http://localhost
# ANYTHINGLLM_API_KEY=your-dify-dataset-api-key-here
# ANYTHINGLLM_WORKSPACE=<dataset-id>

# ── Admin API ───────────────────────────────────────────────────────
# Secret key for the admin HTTP API (Authorization: Bearer <key>)
ADMIN_API_KEY=change-me-to-a-strong-secret
ADMIN_PORT=4000

# ── CORS (optional) ─────────────────────────────────────────────────
# Set to a specific origin to restrict access, or leave blank to deny all
# CORS_ORIGIN=http://localhost:5173

# ── Runtime mode ────────────────────────────────────────────────────
# "mcp"   – stdio MCP server only  (connect directly from LLM client)
# "admin" – HTTP admin API only
# "both"  – admin HTTP + MCP stdio  (default)
MODE=both

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
